{
  "date": "2026-06-23",
  "model": "Qwen3-30B-A3B Q4_K_M GGUF (17.3 GB)",
  "gpu": "RTX 5080 16GB + RTX 5060 Ti 16GB",
  "experiments": {
    "A_cold_hot_cache": {
      "tool": "ftllm --moe_device disk, 5 requests, max_tokens=80",
      "disks": {
        "BIWIN_EXT4": {"mount": "/", "fio_4k_iops": 290671, "cold_tps": 7.41, "hot_tps": 7.96, "hot_boost": 1.07},
        "nvme2n1_NTFS": {"mount": "/mnt/ai_ssd0", "fio_4k_iops": 207569, "cold_tps": 4.57, "hot_tps": 8.24, "hot_boost": 1.80},
        "nvme1n1_NTFS": {"mount": "/mnt/ai_ssd1", "fio_4k_iops": 21272, "cold_tps": 5.00, "hot_tps": 8.14, "hot_boost": 1.63},
        "nvme3n1_NTFS": {"mount": "/mnt/ai_ssd2", "fio_4k_iops": 128757, "cold_tps": 5.39, "hot_tps": 7.45, "hot_boost": 1.38}
      }
    },
    "C_fio_benchmark": {
      "tool": "fio direct=1 ioengine=libaio iodepth=32",
      "disks": {
        "nvme0n1_BIWIN": {"4k_iops": 290671, "4k_bw_mbs": 1186, "4k_lat_us": 109.3, "128k_bw_mbs": 8760, "128k_iops": 66832},
        "nvme1n1":        {"4k_iops": 21272,  "4k_bw_mbs": 87,    "4k_lat_us": 1502.8,"128k_bw_mbs": 2015,  "128k_iops": 15373},
        "nvme2n1":        {"4k_iops": 207569, "4k_bw_mbs": 850,   "4k_lat_us": 152.7, "128k_bw_mbs": 2410,  "128k_iops": 18390},
        "nvme3n1":        {"4k_iops": 128757, "4k_bw_mbs": 527,   "4k_lat_us": 247.2, "128k_bw_mbs": 1694,  "128k_iops": 12923}
      }
    }
  },
  "key_findings": [
    "fio 4K IOPS 与 SSD offload TPS 直接相关: 290K/208K/129K/21K IOPS → 7.4-8.0 tps (BIWIN/nvme2/nvme3/nvme1)",
    "nvme1n1 只有 21K 4K IOPS,延迟 1.5ms — 这是慢盘,但 ftllm 主要用 page cache 所以 TPS 还能保持 8.1",
    "NTFS 冷启动严重退化 (cold 4.5-5.4 tps),热态恢复 (hot 7.5-8.2 tps),ext4 冷热差距小 (+7%)",
    "冷热比 NVFS 是 1.4-1.8x 提升,ext4 只有 1.07x 提升 (ext4 元数据缓存更激进)",
    "SSD 实际利用率仅 1-2% (fio 测得 290K IOPS → 130 tps 理论,但实际只跑 7-8 tps)",
    "瓶颈不是 SSD 本身,是 ftllm MoE expert 加载方式 (每 expert 单独 mmap+decode,不是批量 4K IO)"
  ],
  "next_steps": [
    "P1: bpftrace biosnoop 验证 IO 大小分布 (4K vs 1MB)",
    "P1: /proc/pid/io 量化每请求总 read_bytes",
    "P1: 时间序列对齐找性能抖动",
    "P2: nvidia-smi dmon 看 GPU 端带宽"
  ]
}
